{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable recipe title"
        },
        "slug": {
          "description": "URL-safe identifier, matches the filename without .json",
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "description": "ISO 639-1 two-letter language code"
        },
        "source": {
          "description": "Optional URL of the original recipe",
          "type": "string",
          "pattern": "^https?:\\/\\/"
        },
        "originalText": {
          "type": "string",
          "minLength": 1,
          "description": "Full original recipe text in markdown for side-by-side review"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Categorization tags for filtering and search"
        },
        "servings": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Number of servings the recipe yields"
        },
        "totalTime": {
          "type": "object",
          "properties": {
            "relaxed": {
              "type": "number",
              "minimum": 0,
              "description": "Total time in minutes with all prep front-loaded (relaxed mode)"
            },
            "optimized": {
              "type": "number",
              "minimum": 0,
              "description": "Total time in minutes with prep distributed into idle windows (optimized mode)"
            }
          },
          "required": [
            "relaxed",
            "optimized"
          ],
          "additionalProperties": false
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ],
          "description": "Recipe difficulty level"
        },
        "notes": {
          "description": "Optional free-form notes about the recipe",
          "type": "string"
        }
      },
      "required": [
        "title",
        "slug",
        "language",
        "originalText",
        "tags",
        "servings",
        "totalTime",
        "difficulty"
      ],
      "additionalProperties": false,
      "description": "Recipe metadata"
    },
    "ingredients": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this ingredient, referenced by operations",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable ingredient name"
          },
          "quantity": {
            "type": "number",
            "description": "Amount in the specified unit"
          },
          "unit": {
            "type": "string",
            "minLength": 1,
            "description": "Unit of measurement (metric preferred: g, ml, whole, cloves, etc.)"
          },
          "group": {
            "type": "string",
            "minLength": 1,
            "description": "Category for shopping list aggregation (e.g., vegetables, meat, dairy)"
          }
        },
        "required": [
          "id",
          "name",
          "quantity",
          "unit",
          "group"
        ],
        "additionalProperties": false
      },
      "description": "Ingredients used in this recipe"
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this piece of equipment",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable equipment name"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991,
            "description": "Number of this item needed"
          }
        },
        "required": [
          "id",
          "name",
          "count"
        ],
        "additionalProperties": false
      },
      "description": "Equipment needed for this recipe"
    },
    "operations": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this operation, referenced by other operations or finishSteps",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "prep",
              "cook"
            ],
            "description": "Whether this is a preparation or cooking step"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "Verb describing the operation (e.g., dice, sauté, simmer, boil)"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "description": "Array of ingredient IDs or previous operation IDs forming the DAG edges"
          },
          "equipment": {
            "description": "Equipment used by this operation",
            "type": "object",
            "properties": {
              "use": {
                "description": "Equipment ID being used",
                "type": "string",
                "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
              },
              "release": {
                "type": "boolean",
                "description": "If true, equipment is freed after this operation"
              }
            },
            "required": [
              "use",
              "release"
            ],
            "additionalProperties": false
          },
          "time": {
            "type": "number",
            "description": "Total duration of the operation in minutes"
          },
          "activeTime": {
            "type": "number",
            "description": "Minutes of active attention required (0 for passive operations like simmering)"
          },
          "scalable": {
            "description": "If false, time does not change when scaling servings. Defaults to true.",
            "type": "boolean"
          },
          "heat": {
            "description": "Heat level (e.g., low, medium, medium-high, high)",
            "type": "string"
          },
          "details": {
            "description": "Additional instructions for this operation",
            "type": "string"
          },
          "output": {
            "description": "Sub-product ID this operation produces",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "required": [
          "id",
          "type",
          "action",
          "inputs",
          "time",
          "activeTime"
        ],
        "additionalProperties": false
      },
      "description": "Ordered operations forming the recipe DAG"
    },
    "subProducts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this sub-product",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable name for the intermediate product"
          },
          "finalOp": {
            "description": "Operation ID that produces this sub-product",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "required": [
          "id",
          "name",
          "finalOp"
        ],
        "additionalProperties": false
      },
      "description": "Intermediate products created during cooking"
    },
    "finishSteps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "Verb describing the finishing action"
          },
          "inputs": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "description": "Array of operation IDs (always operation IDs, never sub-product IDs)"
          },
          "details": {
            "description": "Additional instructions for this finishing step",
            "type": "string"
          }
        },
        "required": [
          "action",
          "inputs"
        ],
        "additionalProperties": false
      },
      "description": "Final plating and serving steps"
    }
  },
  "required": [
    "meta",
    "ingredients",
    "equipment",
    "operations",
    "subProducts",
    "finishSteps"
  ],
  "additionalProperties": false,
  "description": "Structured recipe data model for the Recipe Visualization App",
  "$id": "https://github.com/lauriliivamagi/recipes/blob/master/config/recipe-schema.json"
}
